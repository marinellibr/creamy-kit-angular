{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "creamy-kit": {
      "projectType": "library",
      "root": "projects/creamy-kit",
      "sourceRoot": "projects/creamy-kit/src",
      "prefix": "kit",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/creamy-kit/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/creamy-kit/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/creamy-kit/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:jest",
          "options": {
            "tsConfig": "projects/creamy-kit/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
