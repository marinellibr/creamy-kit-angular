  "typings": "dist/creamy-kit/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/creamy-kit/index.d.ts",
      "esm2022": "./dist/creamy-kit/esm2022/creamy-kit.mjs",
      "esm": "./dist/creamy-kit/esm2022/creamy-kit.mjs",
      "default": "./dist/creamy-kit/fesm2022/creamy-kit.mjs"
    },
    "./styles": {
      "default": "./dist/creamy-kit/styles/index.css"
    }
  },
  "peerDependencies": {
    "@angular/common": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "rxjs": "~7.8.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/animations": "^18.2.0",
    "@angular/cli": "^18.2.21",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^14.6.2",
    "ng-packagr": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.5.2",
    "zone.js": "~0.14.10"
  }
