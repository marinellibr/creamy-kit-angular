{
  "name": "creamy-kit",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build creamy-kit",
    "watch": "ng build creamy-kit --watch --configuration development",
    "test": "jest --config jest.config.ts",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "prepare": "npm run build"
  },
  "main": "dist/creamy-kit/fesm2022/creamy-kit.mjs",
